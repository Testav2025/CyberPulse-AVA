# CyberPulse AVA Environment Variables
# Copy this file to .env and fill in the values

# Enable live API calls (true) or use seeded mock data (false)
LIVE_INTEGRATIONS=false

# Microsoft Entra ID Configuration
ENTRA_TENANT_ID=your-tenant-id
ENTRA_CLIENT_ID=your-client-id
ENTRA_CLIENT_SECRET=your-client-secret

# Darktrace Configuration
DARKTRACE_BASE_URL=https://your-darktrace-appliance.com
DARKTRACE_PUBLIC_TOKEN=your-public-token
DARKTRACE_PRIVATE_TOKEN=your-private-token

# Pentera Configuration
PENTERA_BASE_URL=https://your-pentera-appliance.com
PENTERA_API_KEY=your-pentera-api-key

# Culture AI Configuration
CULTUREAI_BASE_URL=https://api.culture.ai
CULTUREAI_API_KEY=your-cultureai-api-key
